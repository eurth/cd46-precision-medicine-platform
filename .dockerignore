# OncoBridge Intelligence — Docker build exclusions
# Keep image lean; runtime data is provided via Coolify volume mount

# Version control
.git
.gitignore
.gitattributes

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.venv
venv
*.egg-info

# Secrets — never baked into image
.env
.env.*
.streamlit/secrets.toml

# Data — include processed CSVs and genie summaries (small, in git)
# Exclude large raw source files only
data/raw/
data/logs/
data/processed/kg_ready/

# Large raw GENIE parquets (not needed by app UI)
data/genie/prad_mrna.parquet
data/genie/prad_cna.parquet
data/genie/prad_mutations.parquet
data/genie/prad_clinical.parquet

# Internal planning docs (not needed at runtime)
MEMORY_BANK/
_archive/

# Dev artefacts
notebooks/
reports/
tests/
.vscode/

# Docs and media
*.md
!README.md
*.docx
*.pptx

# Coolify env template (safe to commit, not needed in image)
coolify.env.example
