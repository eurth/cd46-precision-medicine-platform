# ─────────────────────────────────────────────────────────
# CD46 Precision Medicine Platform — .gitignore
# ─────────────────────────────────────────────────────────

# Secrets — NEVER commit these
.env
.streamlit/secrets.toml

# Memory Bank — local planning docs, not part of deployable codebase
MEMORY_BANK/

# Python runtime
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Data ─────────────────────────────────────────────────
# Raw source files are large (750 MB+ each) — not committed
data/raw/

# Processed CSVs ARE committed (small, needed for Streamlit Cloud demo)
# data/processed/  ← intentionally NOT in gitignore

# KG ready files (regenerated from pipeline)
data/processed/kg_ready/

# GENIE / cBioPortal raw downloads (large parquet files, regenerate with downloader)
data/genie/prad_mrna.parquet
data/genie/prad_cna.parquet
data/genie/prad_mutations.parquet
data/genie/prad_clinical.parquet

# Processed GENIE summaries ARE committed (small, needed for Streamlit Cloud)
# data/genie/genie_cd46_cna_summary.parquet   <- committed
# data/genie/genie_psma_cd46_cooccurrence.parquet <- committed
# data/genie/genie_mutation_summary.parquet   <- committed

# ── Logs and build artefacts ─────────────────────────────
pipeline.log
*.log
# Visitor tracking log (operational data, not source)
data/logs/visitor_log.csv
reports/figures/*.png
reports/figures/*.pdf
*.html

# Notebooks checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/settings.json
.idea/
*.swp
*.swo

# Test / coverage
.coverage
htmlcov/
.pytest_cache/
cd46_precision_medicine_platform.code-workspace

# Ad-hoc test & scratch scripts
test_*.py
*_test.py
scratch_*.py

# Log and output dumps
*.log
streamlit_log.txt
output*.txt
synapse_test_output*.txt
genie_cancers.txt
check_parquet.txt

# Raw GENIE downloads (too large for Git)
data/raw/*.txt
data/raw/*.gz
