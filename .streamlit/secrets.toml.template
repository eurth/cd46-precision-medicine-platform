# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────
# For LOCAL DEVELOPMENT: copy this file to .streamlit/secrets.toml
# and fill in real values. This file is in .gitignore — never commit it.
#
# For STREAMLIT COMMUNITY CLOUD: paste these key=value pairs into
# the "Secrets" text box in your app's Settings → Secrets panel.
# ─────────────────────────────────────────────────────────

# Neo4j AuraDB (or any Bolt-compatible instance)
NEO4J_URI      = "neo4j+s://YOUR_INSTANCE.databases.neo4j.io"
NEO4J_USERNAME = "YOUR_USERNAME"
NEO4J_PASSWORD = "YOUR_PASSWORD"

# OpenAI (GPT-4o)
OPENAI_API_KEY = "sk-proj-..."

# Google Gemini
GEMINI_API_KEY = "AIza..."

# Optional — leave blank if unused
CLINICALTRIALS_API_KEY = ""
CHEMBL_API_KEY         = ""
