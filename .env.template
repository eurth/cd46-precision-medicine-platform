# LLM APIs
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# AuraDB Free (Neo4j)
# Create free account at: https://neo4j.com/cloud/platform/aura-graph-database/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_auradb_password_here

# Synapse (AACR GENIE — PHASE 2 ONLY)
# Get token from: https://accounts.synapse.org/Profile:profile/settings
SYNAPSE_AUTH_TOKEN=your_synapse_personal_access_token_here

# PubMed (Entrez)
ENTREZ_EMAIL=your_email@institution.edu

# Optional: LangSmith tracing
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=cd46-platform
